{
  "name": "alura-clean-code",
  "version": "1.0.0",
  "description": "Projeto inicial com más práticas para o curso de Clean Code.",
  "main": "index.ts",
  "scripts": {
    "start": "node node_modules/ts-node/dist/bin.js src/index.ts",
    "dev": "node node_modules/nodemon/bin/nodemon.js --legacy-watch --watch src --ext ts,json --exec \"node node_modules/ts-node/dist/bin.js src/index.ts\"",
    "typecheck:watch": "node node_modules/typescript/bin/tsc --noEmit --watch",
    "start:dev": "node node_modules/concurrently/dist/bin/concurrently.js \"npm run typecheck:watch\" \"npm run dev\""
  },
  "keywords": [
    "clean-code",
    "refactoring",
    "typescript",
    "express"
  ],
  "author": "Aluno",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.8.10",
    "concurrently": "^9.1.2",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}